# Production build configuration (loaded automatically by Vite for `vite build`).
# These point the deployed SPA at the Render-hosted backend.
# Not secrets — just the public API + WebSocket origins.
#
# Local `npm run dev` ignores this file and falls back to localhost defaults.

VITE_API_BASE_URL=https://dronaai-wvnc.onrender.com/api/v1
VITE_WS_BASE_URL=wss://dronaai-wvnc.onrender.com
