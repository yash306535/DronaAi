# DRONA AI backend environment configuration
# Copy to `.env` and fill in values. NEVER commit a populated `.env`.
# Secret values are loaded at startup; absence of a REQUIRED secret aborts
# startup with an error naming the missing key (Requirement 15.1, 15.2).

# === Required secrets (startup aborts if absent) ===
# JWT signing secret (HS256). Use a long, random value.
JWT_SECRET=
# OpenAI API key (Stage 2 Vision confirmation + LLM generation).
OPENAI_API_KEY=

# === Optional secrets ===
# Anthropic API key (alternative LLM provider for Architect/Analyst).
ANTHROPIC_API_KEY=
# SMTP password for Herald email notifications (optional channel).
SMTP_PASSWORD=

# === Non-secret application configuration ===
# Deployment environment label: local | staging | production
ENVIRONMENT=local
# SQLAlchemy database URL. SQLite locally; PostgreSQL on deploy.
# On Render this is injected automatically from the managed database
# (see backend/render.yaml -> fromDatabase). Example Postgres URL:
#   postgresql://USER:PASSWORD@HOST:5432/drona
DATABASE_URL=sqlite:///./drona.db
# JWT algorithm and token lifetimes.
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
# Comma-separated CORS allowlist of frontend origins.
FRONTEND_ORIGINS=http://localhost:5173
# Maximum accepted request body size in bytes (default 1 MB).
MAX_BODY_BYTES=1048576
# SMTP (optional email channel for Herald).
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
